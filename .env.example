# Omni9 API deployment environment
# Copy these values into Coolify's environment panel for the API-only app.
# Keep real secrets out of git. Use strong random values for passwords and tokens.

# Coolify / host wrapper
PORT=8080
OMNI9_HOST=0.0.0.0
OMNI9_PORT=8080
OMNI9_WORKERS=1
OMNI9_LOG_LEVEL=info
OMNI9_ENABLE_MQTT_INGEST=1

# Core API
VITE_OMNI_API_URL=https://api.taxsomega.com
APP_ENV=production
APP_NAME=Omni9 API
APP_CORS_ORIGINS=https://your-web-app.example.com,http://localhost:5173,http://localhost:5174,http://localhost,https://localhost,capacitor://localhost,ionic://localhost
DEFAULT_SITE_ID=main_site
JWT_SECRET=replace_with_64_character_random_secret

# PostgreSQL is optional right now, but recommended before real production.
# Example: postgresql://user:password@postgres-host:5432/omni9?options=-csearch_path%3Domni9,public
DATABASE_URL=

# MQTT broker for ESP32 telemetry and commands.
# If MQTT is not hosted yet, set OMNI9_ENABLE_MQTT_INGEST=0 temporarily.
MQTT_HOST=mosquitto.taxsomega.com
MQTT_PORT=443
MQTT_USERNAME=${SERVICE_USER_MOSQUITTO}
MQTT_PASSWORD=${SERVICE_PASSWORD_MOSQUITTO}
MQTT_BASE_TOPIC=omni9
MQTT_TRANSPORT=tcp
MQTT_TLS=true
MQTT_WS_PATH=/mqtt
SERVICE_FQDN_MOSQUITTO=mosquitto.taxsomega.com
SERVICE_URL_MOSQUITTO=https://mosquitto.taxsomega.com
SERVICE_URL_MOSQUITTO_1883=
SERVICE_FQDN_MOSQUITTO_1883=
SERVICE_USER_MOSQUITTO=omni_backend
SERVICE_PASSWORD_MOSQUITTO=replace_with_backend_mqtt_password
ALLOW_ANONYMOUS=true
REQUIRE_CERTIFICATE=false

# Current production route uses MQTT-over-TLS on 443 through Traefik.
# Only set SERVICE_URL_MOSQUITTO_1883/SERVICE_FQDN_MOSQUITTO_1883 if raw 1883 is publicly reachable.
# If switching to MQTT-over-WebSockets later, use MQTT_TRANSPORT=websockets
# and keep MQTT_TLS=true with the configured MQTT_WS_PATH.

# Shared token used by ESP mesh gateways when opening /v1/mesh/ws.
MESH_GATEWAY_TOKEN=replace_with_mesh_gateway_token

# S3-compatible storage for photos, audio, reports, and evidence.
# Works with SeaweedFS S3, MinIO, Garage, AWS S3, or another S3-compatible endpoint.
STORAGE_DRIVER=s3
S3_ENDPOINT_URL=https://s3.taxsomega.com
S3_REGION=us-east-1
S3_ACCESS_KEY=replace_with_s3_access_key
S3_SECRET_KEY=replace_with_s3_secret_key
S3_BUCKET=omni9-media
S3_PUBLIC_BASE_URL=https://s3.taxsomega.com

# Optional S3 admin endpoint and compatibility aliases.
S3_ADMIN_URL=https://s3-admin.taxsomega.com
SERVICE_URL_S3=https://s3.taxsomega.com
SERVICE_URL_ADMIN=https://s3-admin.taxsomega.com
SERVICE_FQDN_S3=s3.taxsomega.com
SERVICE_FQDN_ADMIN=s3-admin.taxsomega.com
SERVICE_URL_S3_8333=https://s3.taxsomega.com:8333
SERVICE_FQDN_S3_8333=s3.taxsomega.com:8333
SERVICE_URL_ADMIN_23646=https://s3-admin.taxsomega.com:23646
SERVICE_FQDN_ADMIN_23646=s3-admin.taxsomega.com:23646
SERVICE_USER_S3=
SERVICE_PASSWORD_S3=
SERVICE_USER_ADMIN=
SERVICE_PASSWORD_ADMIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SEAWEED_USER_ADMIN=
SEAWEED_PASSWORD_ADMIN=

# AI chat, RAG, and SQL context.
AI_BASE_URL=https://copilot.taxsomega.com
AI_API_KEY=replace_with_ai_api_key
AI_CHAT_MODEL=gpt-5-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_CONTEXT_ROW_LIMIT=20
AI_ENABLE_SQL_CONTEXT=true
AI_ENABLE_RAG=true
AI_ENABLE_WEB_SEARCH=true
SEARXNG_INSTANCES=https://searxng-x553qn4uned8yvitp07nr9j1.taxsomega.com
SEARXNG_TIMEOUT_SECONDS=10
SEARXNG_MAX_INSTANCES=1
AI_DEFAULT_SYSTEM_PROMPT=
AI_MAX_OUTPUT_TOKENS=120

# Voice pipeline. OPENAI_API_KEY can be used as a fallback if provider-specific keys are blank.
AUDIO_BASE_URL=https://api.naga.ac
AUDIO_API_KEY=replace_with_audio_api_key
OPENAI_API_KEY=
STT_MODEL=whisper-large-v3:free
AI_REASONING_MODEL=gpt-5-mini
TTS_MODEL=gpt-4o-mini-tts:free
TTS_VOICE=alloy